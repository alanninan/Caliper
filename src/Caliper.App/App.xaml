<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Caliper.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="CodeFontFamily">Cascadia Mono, Consolas</FontFamily>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <!-- Distinct system colors so added/modified/removed stay distinguishable
                         under a high-contrast theme instead of all rendering as plain window. -->
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemColorHighlightColorBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemColorHotlightColorBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemColorGrayTextColorBrush" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
