<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Caliper.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="CodeFontFamily">Cascadia Mono, Consolas</FontFamily>
            <Thickness x:Key="PagePadding">32,24</Thickness>
            <x:Double x:Key="SectionSpacing">16</x:Double>
            <x:Double x:Key="ControlSpacing">8</x:Double>
            <x:Double x:Key="WidePageWidth">1200</x:Double>
            <x:Double x:Key="EmptyStateWidth">480</x:Double>
            <Style x:Key="WidePageRootGridStyle" TargetType="Grid">
                <Setter Property="MaxWidth" Value="{StaticResource WidePageWidth}" />
                <Setter Property="Padding" Value="{StaticResource PagePadding}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="RowSpacing" Value="{StaticResource SectionSpacing}" />
            </Style>
            <Style x:Key="PageScrollViewerStyle" TargetType="ScrollViewer">
                <Setter Property="Padding" Value="{StaticResource PagePadding}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>
            <Style x:Key="WidePageShellStyle" TargetType="StackPanel">
                <Setter Property="MaxWidth" Value="{StaticResource WidePageWidth}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Spacing" Value="{StaticResource SectionSpacing}" />
            </Style>
            <Style x:Key="PageHeaderGridStyle" TargetType="Grid">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="ColumnSpacing" Value="{StaticResource SectionSpacing}" />
            </Style>
            <Style x:Key="PageHeaderTextStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="{StaticResource ControlSpacing}" />
            </Style>
            <Style x:Key="PageHeaderActionsStyle" TargetType="StackPanel">
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="Spacing" Value="{StaticResource ControlSpacing}" />
            </Style>
            <Style x:Key="StretchListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                    <SolidColorBrush x:Key="DiffChangedBorderBrush" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                    <SolidColorBrush x:Key="DiffChangedBorderBrush" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <!-- D1: Hotlight/GrayText are foreground-only colors (hyperlinks / disabled
                         text) and are not valid HC fill pairings with the default WindowText
                         foreground row text keeps — using them as a Background made diff rows
                         unreadable. All three diff kinds now share the WindowColor/WindowText
                         pairing (readable, HC-compliant) and rely on other-than-color cues to
                         convey kind: the inline `+`/`-`/`~` Prefix column, side-by-side
                         positional semantics (removed = old side only, added = new side only,
                         modified = both sides), and the WindowText underline below via
                         DiffChangedBorderBrush. -->
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffChangedBorderBrush" ResourceKey="SystemColorWindowTextColorBrush" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
