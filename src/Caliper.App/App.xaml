<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Caliper.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="CodeFontFamily">Cascadia Mono, Consolas</FontFamily>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                    <SolidColorBrush x:Key="DiffChangedBorderBrush" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemFillColorSuccessBackgroundBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemFillColorCautionBackgroundBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemFillColorCriticalBackgroundBrush" />
                    <SolidColorBrush x:Key="DiffChangedBorderBrush" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <!-- D1: Hotlight/GrayText are foreground-only colors (hyperlinks / disabled
                         text) and are not valid HC fill pairings with the default WindowText
                         foreground row text keeps — using them as a Background made diff rows
                         unreadable. All three diff kinds now share the WindowColor/WindowText
                         pairing (readable, HC-compliant) and rely on other-than-color cues to
                         convey kind: the inline `+`/`-`/`~` Prefix column, side-by-side
                         positional semantics (removed = old side only, added = new side only,
                         modified = both sides), and the WindowText underline below via
                         DiffChangedBorderBrush. -->
                    <StaticResource x:Key="DiffAddedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffModifiedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffRemovedBackgroundBrush" ResourceKey="SystemColorWindowColorBrush" />
                    <StaticResource x:Key="DiffChangedBorderBrush" ResourceKey="SystemColorWindowTextColorBrush" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
