<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.SchedulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:local="using:Caliper.App.Views"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels">

    <Page.Resources>
        <DataTemplate x:Key="ScheduleRowTemplate" x:DataType="vm:ScheduleItemViewModel">
            <Grid Padding="12,10" ColumnSpacing="8" RowSpacing="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind EnabledStatusText, Mode=OneWay}" />
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontFamily="{StaticResource CodeFontFamily}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind Cron, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" TextTrimming="CharacterEllipsis">
                    <Run Text="Next: " /><Run Text="{x:Bind NextOccurrenceText, Mode=OneWay}" /><Run Text="   ·   Last: " /><Run Text="{x:Bind LastResultText, Mode=OneWay}" />
                </TextBlock>
                <Button
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    AutomationProperties.AutomationId="RunScheduleNowListButton"
                    Click="RunNow_Click"
                    Content="{x:Bind local:SchedulesPage.RunButtonText(IsRunning), Mode=OneWay}"
                    IsEnabled="{x:Bind converters:XamlConverters.InvertBool(IsRunning), Mode=OneWay}"
                    Tag="{x:Bind}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ScheduleDetailTemplate" x:DataType="vm:ScheduleItemViewModel">
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox AutomationProperties.AutomationId="ScheduleNameTextBox" Header="Name" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Bottom" AutomationProperties.AutomationId="ScheduleEnabledToggle" IsOn="{x:Bind Enabled, Mode=TwoWay}" OffContent="Disabled" OnContent="Enabled" />
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <TextBox AutomationProperties.AutomationId="ScheduleCronTextBox" FontFamily="{StaticResource CodeFontFamily}" Header="Cron (5-field)" PlaceholderText="0 6 * * *" Text="{x:Bind Cron, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="1" AutomationProperties.AutomationId="ScheduleTimeZoneTextBox" Header="Time zone" PlaceholderText="local" Text="{x:Bind TimeZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind CronValidationText, Mode=OneWay}" TextWrapping="Wrap" />

                <TextBox AutomationProperties.AutomationId="SchedulePromptTextBox" AcceptsReturn="True" Header="Prompt" MinHeight="120" MaxHeight="220" Text="{x:Bind Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox AutomationProperties.AutomationId="ScheduleWorkingRootTextBox" Header="Working root" PlaceholderText="Inherit global working root" Text="{x:Bind WorkingRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="1" AutomationProperties.AutomationId="ScheduleModelTextBox" Header="Model" PlaceholderText="Inherit default model" Text="{x:Bind Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <NumberBox AutomationProperties.AutomationId="ScheduleMaxStepsNumberBox" Header="Max steps" Minimum="1" PlaceholderText="Inherit global max steps" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind MaxStepsValue, Mode=TwoWay}" />

                <TextBlock
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ValidationMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(HasValidationMessage), Mode=OneWay}" />

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource ControlCornerRadius}">
                    <StackPanel Spacing="8">
                        <ToggleSwitch AutomationProperties.AutomationId="ScheduleOverridePermissionsToggle" Header="Override permissions" IsOn="{x:Bind OverridePermissions, Mode=TwoWay}" />
                        <StackPanel Spacing="8" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(OverridePermissions), Mode=OneWay}">
                            <ComboBox AutomationProperties.AutomationId="SchedulePermissionModePicker" Header="Mode" SelectedItem="{x:Bind PermissionsModeText, Mode=TwoWay}">
                                <x:String>AskAlways</x:String>
                                <x:String>Auto</x:String>
                                <x:String>Plan</x:String>
                            </ComboBox>
                            <TextBox AutomationProperties.AutomationId="ScheduleAllowlistTextBox" AcceptsReturn="True" Header="Shell auto-allowlist (one per line)" MaxHeight="100" Text="{x:Bind ShellAutoAllowlistText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <TextBox AutomationProperties.AutomationId="ScheduleFileRootsTextBox" AcceptsReturn="True" Header="Auto-allow file roots (one per line)" MaxHeight="100" Text="{x:Bind AutoAllowFileRootsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Allowlists only take effect when Mode is Auto — the config validator rejects them under any other mode. A bare &quot;*&quot; entry also requires the Container execution backend."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button AutomationProperties.AutomationId="ScheduleDetailRunNowButton" Click="RunNow_Click" Content="{x:Bind local:SchedulesPage.RunButtonText(IsRunning), Mode=OneWay}" IsEnabled="{x:Bind converters:XamlConverters.InvertBool(IsRunning), Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" Tag="{x:Bind}" />
                    <ProgressRing
                        Grid.Column="1"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        IsActive="{x:Bind IsRunning, Mode=OneWay}"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(IsRunning), Mode=OneWay}" />
                </Grid>
                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind converters:XamlConverters.HasText(RunOutcomeText), Mode=OneWay}"
                    Message="{x:Bind RunOutcomeText, Mode=OneWay}"
                    Severity="{x:Bind converters:XamlConverters.StatusSeverity(RunOutcomeIsError), Mode=OneWay}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ScheduledRunHistoryRowTemplate" x:DataType="vm:ScheduledRunItemViewModel">
            <Grid
                Padding="12,10"
                AutomationProperties.Name="{x:Bind AccessibleName, Mode=OneTime}"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="184" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind StatusText, Mode=OneTime}" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{x:Bind ScheduleName, Mode=OneTime}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="{x:Bind Reason, Mode=OneTime}" TextTrimming="CharacterEllipsis" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind ProgressText, Mode=OneTime}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind UpdatedAtText, Mode=OneTime}" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="4" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                    <ProgressRing
                        Width="16"
                        Height="16"
                        IsActive="{x:Bind IsResuming, Mode=OneWay}"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(IsResuming), Mode=OneWay}" />
                    <Button
                        AutomationProperties.AutomationId="ResumeScheduledRunButton"
                        Click="ResumeHistoryRun_Click"
                        Content="{x:Bind local:SchedulesPage.ResumeHistoryButtonText(IsResuming), Mode=OneWay}"
                        IsEnabled="{x:Bind converters:XamlConverters.InvertBool(IsResuming), Mode=OneWay}"
                        Tag="{x:Bind}"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(CanResume), Mode=OneTime}" />
                    <Button
                        AutomationProperties.AutomationId="OpenScheduledRunChatButton"
                        Click="OpenHistorySession_Click"
                        Content="Open chat"
                        Tag="{x:Bind}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Style="{StaticResource WidePageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="Schedules" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Run agent prompts on a cron schedule, or trigger any of them on demand." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel x:Name="ScheduleActions" Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}">
                    <Button AutomationProperties.AutomationId="AddScheduleButton" Command="{x:Bind ViewModel.AddJobCommand}" Content="Add" />
                    <Button AutomationProperties.AutomationId="DiscardSchedulesButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                    <Button AutomationProperties.AutomationId="SaveSchedulesButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>

            <SelectorBar
                x:Name="ScheduleViewSelector"
                Grid.Row="1"
                AutomationProperties.AutomationId="ScheduleViewSelector"
                SelectionChanged="ScheduleViewSelector_SelectionChanged">
                <SelectorBarItem x:Name="SchedulesSelectorItem" AutomationProperties.AutomationId="SchedulesModeItem" IsSelected="True" Text="Schedules" />
                <SelectorBarItem x:Name="HistorySelectorItem" AutomationProperties.AutomationId="ScheduleHistoryModeItem" Text="History" />
            </SelectorBar>

            <ScrollViewer
                x:Name="SchedulesEditorScroll"
                Grid.Row="2"
                HorizontalContentAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="{StaticResource SectionSpacing}">

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}" />

            <StackPanel Spacing="4">
                <settings:SettingsCard
                    Description="Jobs fire on their cron schedule only while this window stays open; permission prompts are auto-denied and reported (unattended policy), the same as a scheduled job run elsewhere. Headless scheduling remains --serve."
                    Header="Run scheduler while the app is open">
                    <ToggleSwitch AutomationProperties.AutomationId="RunSchedulerToggle" IsOn="{x:Bind ViewModel.RunSchedulerEnabled, Mode=TwoWay}" />
                </settings:SettingsCard>
                <TextBlock
                    Margin="16,0"
                    AutomationProperties.AutomationId="SchedulerStatusText"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.SchedulerStatusText, Mode=OneWay}" />
            </StackPanel>

            <ProgressRing
                AutomationProperties.AutomationId="SchedulesLoadingRing"
                HorizontalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsLoading), Mode=OneWay}" />

            <Border
                MaxWidth="480"
                Padding="28,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource OverlayCornerRadius}"
                Visibility="{x:Bind local:SchedulesPage.EmptyStateVisibility(ViewModel.IsLoading, ViewModel.HasJobs), Mode=OneWay}">
                <StackPanel Spacing="16">
                    <FontIcon HorizontalAlignment="Center" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE787;" />
                    <TextBlock HorizontalAlignment="Center" Text="No schedules yet" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Add a schedule to run an agent prompt automatically on a cron expression, or trigger it whenever you like."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="EmptyStateAddScheduleButton"
                        HorizontalAlignment="Center"
                        AutomationProperties.AutomationId="EmptyStateAddScheduleButton"
                        Command="{x:Bind ViewModel.AddJobCommand}"
                        Content="Add schedule"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="16" Visibility="{x:Bind local:SchedulesPage.MasterDetailVisibility(ViewModel.IsLoading, ViewModel.HasJobs), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <Button AutomationProperties.AutomationId="RemoveScheduleButton" HorizontalAlignment="Right" Click="RemoveSelectedJob_Click" Content="Remove" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}">
                        <ListView
                            AutomationProperties.AutomationId="ScheduleList"
                            ItemTemplate="{StaticResource ScheduleRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}"
                            MaxHeight="600"
                            SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
                            SelectionMode="Single" />
                    </Border>
                </StackPanel>
                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}">
                    <ScrollViewer MaxHeight="700">
                        <ContentControl
                            HorizontalContentAlignment="Stretch"
                            Content="{x:Bind ViewModel.SelectedJob, Mode=OneWay}"
                            ContentTemplate="{StaticResource ScheduleDetailTemplate}" />
                    </ScrollViewer>
                </Border>
            </Grid>
                </StackPanel>
            </ScrollViewer>

            <Grid
                x:Name="ScheduleHistoryPanel"
                Grid.Row="2"
                RowSpacing="{StaticResource SectionSpacing}"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Style="{StaticResource PageHeaderGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Scheduled run history" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.HistorySummaryText, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}">
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsHistoryLoading, Mode=OneWay}"
                            Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsHistoryLoading), Mode=OneWay}" />
                        <Button
                            AutomationProperties.AutomationId="RefreshScheduleHistoryButton"
                            Command="{x:Bind ViewModel.LoadHistoryCommand}"
                            Content="Refresh" />
                    </StackPanel>
                </Grid>

                <InfoBar
                    Grid.Row="1"
                    IsClosable="False"
                    IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.HistoryStatusMessage), Mode=OneWay}"
                    Message="{x:Bind ViewModel.HistoryStatusMessage, Mode=OneWay}"
                    Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.HistoryStatusIsError), Mode=OneWay}" />

                <Border
                    Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Visibility="{x:Bind local:SchedulesPage.HistoryVisibility(ViewModel.IsHistoryLoading, ViewModel.HasRunHistory), Mode=OneWay}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="184" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Status" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Column="1" Text="Schedule" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Column="2" Text="Progress" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Column="3" Text="Updated" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </Grid>
                        <ListView
                            Grid.Row="1"
                            AutomationProperties.AutomationId="ScheduleHistoryList"
                            ItemContainerStyle="{StaticResource StretchListViewItemStyle}"
                            ItemTemplate="{StaticResource ScheduledRunHistoryRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.RunHistory, Mode=OneWay}"
                            SelectionMode="None" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    MaxWidth="{StaticResource EmptyStateWidth}"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Visibility="{x:Bind local:SchedulesPage.HistoryEmptyVisibility(ViewModel.IsHistoryLoading, ViewModel.HasRunHistory), Mode=OneWay}">
                    <StackPanel Spacing="12">
                        <TextBlock HorizontalAlignment="Center" Text="No scheduled runs yet" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="History appears here after a schedule runs automatically or through Run now."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
    </Grid>
</Page>
