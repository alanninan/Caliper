<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:markdown="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels">

    <Grid Padding="36,28" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="8">
                <TextBlock Text="Skills" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Specialized instruction packs the agent can load for focused workflows."
                    TextWrapping="Wrap" />
                <TextBlock
                    AutomationProperties.AutomationId="SkillsStatusText"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Top"
                AutomationProperties.AutomationId="RefreshSkillsButton"
                Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>
        </Grid>
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource OverlayCornerRadius}">
                <Grid>
                    <ListView
                        x:Name="SkillList"
                        AutomationProperties.AutomationId="SkillList"
                        ItemsSource="{x:Bind ViewModel.Skills, Mode=OneWay}"
                        SelectionChanged="SkillList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SkillItemViewModel">
                                <StackPanel Padding="16" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <InfoBar
                        Margin="16"
                        IsClosable="False"
                        IsOpen="{x:Bind converters:XamlConverters.InvertBool(ViewModel.HasSkills), Mode=OneWay}"
                        Message="No skills were discovered in the configured skills directory."
                        Severity="Informational" />
                </Grid>
            </Border>
            <Border
                Grid.Column="1"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource OverlayCornerRadius}">
                <ScrollViewer>
                    <markdown:MarkdownTextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SkillBody, Mode=OneWay}" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
