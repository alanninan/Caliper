<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.MemoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:markdown="using:CommunityToolkit.WinUI.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels">

    <Grid Style="{StaticResource WidePageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="CompactMemory">
                    <VisualState.Setters>
                        <Setter Target="MemorySecondaryColumn.Width" Value="0" />
                        <Setter Target="MemorySelector.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideMemory">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1008" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MemoryPrimaryColumn.Width" Value="420" />
                        <Setter Target="MemorySecondaryColumn.Width" Value="*" />
                        <Setter Target="MemorySelector.Visibility" Value="Collapsed" />
                        <Setter Target="EntriesPanel.Visibility" Value="Visible" />
                        <Setter Target="ProjectPanel.Visibility" Value="Visible" />
                        <Setter Target="ProjectPanel.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid Style="{StaticResource PageHeaderGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                <TextBlock Text="Memory" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Global/project memory and the project document that can be surfaced into prompts." TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}">
                <Button AutomationProperties.AutomationId="MemoryRefreshButton" Command="{x:Bind ViewModel.RefreshMemoryCommand}" Content="Refresh memory" />
            </StackPanel>
        </Grid>
        <InfoBar
            Grid.Row="1"
            AutomationProperties.AutomationId="MemoryStatusInfoBar"
            IsClosable="False"
            IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            Severity="Informational" />
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <settings:SettingsCard Header="Entries" Description="{x:Bind ViewModel.MemoryCountText, Mode=OneWay}" />
            <settings:SettingsCard Grid.Column="1" Header="Project document" Description="{x:Bind ViewModel.ProjectDocumentPath, Mode=OneWay}" />
        </Grid>
        <Expander
            x:Name="AddMemoryExpander"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            AutomationProperties.AutomationId="AddMemoryExpander"
            Header="Remember a new fact">
            <StackPanel Spacing="8">
                <ComboBox
                    Width="200"
                    AutomationProperties.AutomationId="MemoryScopePicker"
                    Header="Scope"
                    SelectedIndex="{x:Bind ViewModel.MemoryScopeIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Global" />
                    <ComboBoxItem Content="Project" />
                </ComboBox>
                <TextBox
                    x:Name="MemoryKeyBox"
                    AutomationProperties.AutomationId="MemoryKeyBox"
                    Header="Key"
                    PlaceholderText="e.g. code-style"
                    Text="{x:Bind ViewModel.MemoryKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    AutomationProperties.AutomationId="MemoryValueBox"
                    MinHeight="120"
                    AcceptsReturn="True"
                    Header="Value"
                    PlaceholderText="What should Caliper remember?"
                    Text="{x:Bind ViewModel.MemoryValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
                <Button
                    AutomationProperties.AutomationId="RememberMemoryButton"
                    Command="{x:Bind ViewModel.RememberCommand}"
                    Content="Remember"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Expander>
        <SelectorBar x:Name="MemorySelector" Grid.Row="4" SelectionChanged="MemorySelector_SelectionChanged">
            <SelectorBarItem x:Name="EntriesSelectorItem" Text="Entries" IsSelected="True" />
            <SelectorBarItem Text="Project document" />
        </SelectorBar>
        <Grid Grid.Row="5" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MemoryPrimaryColumn" Width="*" />
                <ColumnDefinition x:Name="MemorySecondaryColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Border x:Name="EntriesPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}">
                <Grid>
                    <ListView AutomationProperties.AutomationId="MemoryList" ItemsSource="{x:Bind ViewModel.Memories, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemoryItemViewModel">
                                <Grid Padding="16" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind Key}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                        <TextBlock Text="{x:Bind Scope}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Top"
                                        AutomationProperties.AutomationId="{x:Bind EditAutomationId}"
                                        AutomationProperties.Name="Edit this memory"
                                        Click="EditMemory_Click"
                                        Tag="{x:Bind}">
                                        <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                    </Button>
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Top"
                                        AutomationProperties.AutomationId="{x:Bind ForgetAutomationId}"
                                        AutomationProperties.Name="Forget this memory"
                                        Tag="{x:Bind}">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel MinWidth="200" Spacing="12">
                                                    <TextBlock Text="{x:Bind ForgetConfirmText}" TextWrapping="Wrap" />
                                                    <Button
                                                        HorizontalAlignment="Right"
                                                        AutomationProperties.AutomationId="{x:Bind ConfirmForgetAutomationId}"
                                                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                                        Click="ConfirmForget_Click"
                                                        Content="Forget"
                                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                        Tag="{x:Bind}" />
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Margin="24" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="{x:Bind converters:XamlConverters.InvertBoolToVisibility(ViewModel.HasMemories), Mode=OneWay}">
                        <TextBlock Text="Nothing remembered yet" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Add a fact Caliper should remember across conversations." TextAlignment="Center" TextWrapping="Wrap" />
                        <Button HorizontalAlignment="Center" AutomationProperties.AutomationId="RememberFactEmptyButton" Click="RememberFactEmpty_Click" Content="Remember a fact" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="ProjectPanel" Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}" Visibility="Collapsed">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Project document" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ProjectDocumentPath, Mode=OneWay}" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <markdown:MarkdownTextBlock IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.ProjectDocument, Mode=OneWay}" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Visibility="{x:Bind converters:XamlConverters.InvertBoolToVisibility(ViewModel.HasProjectDocument), Mode=OneWay}">
                        <TextBlock Text="No project memory file" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Create the configured file without replacing anything that already exists." TextAlignment="Center" TextWrapping="Wrap" />
                        <Button AutomationProperties.AutomationId="CreateProjectMemoryButton" Command="{x:Bind ViewModel.CreateProjectDocumentCommand}" Content="Create project file" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
