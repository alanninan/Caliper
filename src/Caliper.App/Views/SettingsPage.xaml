<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <NavigationView
        x:Name="SettingsNav"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="240"
        PaneDisplayMode="Auto"
        SelectionChanged="SettingsNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItemHeader Content="Basics" />
            <NavigationViewItem AutomationProperties.AutomationId="GeneralSettingsNavItem" Content="General" Tag="General">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="ModelsProvidersSettingsNavItem" Content="Models &amp; providers" Tag="ModelsProviders">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE950;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemHeader Content="Agent" />
            <NavigationViewItem AutomationProperties.AutomationId="AgentBehaviorSettingsNavItem" Content="Agent behavior" Tag="AgentBehavior">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8BD;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="ContextMemorySettingsNavItem" Content="Context &amp; memory" Tag="ContextMemory">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8F1;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="ToolsSettingsNavItem" Content="Tools" Tag="Tools">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE90F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="SubagentsSettingsNavItem" Content="Subagents" Tag="Subagents">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE716;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemHeader Content="Safety" />
            <NavigationViewItem AutomationProperties.AutomationId="PermissionsSettingsNavItem" Content="Permissions" Tag="Permissions">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE72E;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="ExecutionSettingsNavItem" Content="Execution" Tag="Execution">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE756;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemHeader Content="Integrations" />
            <NavigationViewItem AutomationProperties.AutomationId="McpSettingsNavItem" Content="MCP servers" Tag="Mcp">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE774;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem AutomationProperties.AutomationId="SearchSettingsNavItem" Content="Search" Tag="Search">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE721;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemHeader Content="Advanced" />
            <NavigationViewItem AutomationProperties.AutomationId="AdvancedSettingsNavItem" Content="Advanced" Tag="Advanced">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE90F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <Frame
            x:Name="SettingsFrame"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch" />
    </NavigationView>
</Page>
