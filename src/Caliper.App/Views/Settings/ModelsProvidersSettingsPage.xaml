<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.ModelsProvidersSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels.Settings">

    <!--
        D5: the model catalog below can hold hundreds of OpenRouter models, so it needs a
        virtualizing ListView with the remaining page height, not a ScrollViewer-wrapped
        StackPanel/ItemsControl. Mirrors ToolsSettingsPage's Grid pattern (Auto rows for
        header/status/form content, a trailing * row for the list) instead of one page-level
        ScrollViewer around everything. The upper form sections (Active model, OpenRouter,
        Gemini) move into their own ScrollViewer. Its row needs the MaxHeight: a ScrollViewer
        in an unbounded Auto row is measured with infinite height, so it would never scroll —
        it would just grow to its full expanded-content height and starve the catalog row.
        Capping the row keeps the collapsed-expanders common case unchanged (it's shorter than
        the cap) while an expanded form section scrolls instead of pushing the catalog to zero.
    -->
    <Grid Style="{StaticResource WidePageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" MaxHeight="380" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Style="{StaticResource PageHeaderGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                <TextBlock Text="Models &amp; providers" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.RuntimeSummary, Mode=OneWay}" TextWrapping="Wrap" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.CatalogSummaryText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Visibility="{x:Bind converters:XamlConverters.HasTextToVisibility(ViewModel.CatalogSummaryText), Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                <Button AutomationProperties.AutomationId="DiscardModelsProvidersButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                <Button AutomationProperties.AutomationId="SaveModelsProvidersButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
            <InfoBar.ActionButton>
                <Button
                    AutomationProperties.AutomationId="RestartAppButton"
                    Click="RestartApp_Click"
                    Content="Restart Caliper"
                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <ScrollViewer
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Stretch" Spacing="{StaticResource SectionSpacing}">
                <settings:SettingsExpander Header="Active model" Description="Provider determines the catalog, credentials, and request shape.">
                    <ComboBox
                        AutomationProperties.AutomationId="ProviderPicker"
                        DisplayMemberPath="DisplayName"
                        MinWidth="200"
                        ItemsSource="{x:Bind ViewModel.ProviderOptions, Mode=OneWay}"
                        SelectedValue="{x:Bind ViewModel.CurrentProvider, Mode=TwoWay}"
                        SelectedValuePath="Id"
                        SelectionChanged="ProviderPicker_SelectionChanged" />
                    <settings:SettingsExpander.Items>
                        <settings:SettingsCard Header="Model" Description="Type or pick from the catalog below, then Save to make it active.">
                            <AutoSuggestBox
                                x:Name="ModelPicker"
                                AutomationProperties.AutomationId="ModelPicker"
                                MinWidth="320"
                                ItemsSource="{x:Bind ViewModel.FilteredModels, Mode=OneWay}"
                                PlaceholderText="Search or enter a model id"
                                QueryIcon="Find"
                                QuerySubmitted="ModelPicker_QuerySubmitted"
                                SuggestionChosen="ModelPicker_SuggestionChosen"
                                Text="{x:Bind ViewModel.CurrentModel, Mode=OneWay}"
                                TextChanged="ModelPicker_TextChanged">
                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelItemViewModel">
                                        <StackPanel Padding="4" Spacing="2">
                                            <TextBlock Text="{x:Bind Id}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="{x:Bind Capabilities}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Summarizer model" Description="Leave empty to use the main model.">
                            <TextBox AutomationProperties.AutomationId="SummarizerModelTextBox" MinWidth="280" Text="{x:Bind ViewModel.SummarizerModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Model catalog" Description="Loads available models for the active provider.">
                            <Button AutomationProperties.AutomationId="RefreshModelsButton" Command="{x:Bind ViewModel.LoadModelsCommand}" Content="Refresh catalog" />
                        </settings:SettingsCard>
                    </settings:SettingsExpander.Items>
                </settings:SettingsExpander>

                <settings:SettingsExpander Header="OpenRouter" Description="Default provider for chat requests.">
                    <settings:SettingsExpander.Items>
                        <settings:SettingsCard Header="Endpoint">
                            <TextBox AutomationProperties.AutomationId="OpenRouterEndpointTextBox" MinWidth="320" Text="{x:Bind ViewModel.OpenRouterEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="App title">
                            <TextBox AutomationProperties.AutomationId="OpenRouterAppTitleTextBox" MinWidth="220" Text="{x:Bind ViewModel.OpenRouterAppTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="App referer">
                            <TextBox AutomationProperties.AutomationId="OpenRouterAppRefererTextBox" MinWidth="220" Text="{x:Bind ViewModel.OpenRouterAppReferer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="API key" Description="Leave blank to use CALIPER_OPENROUTER_KEY.">
                            <PasswordBox AutomationProperties.AutomationId="OpenRouterApiKeyPasswordBox" MinWidth="220" Password="{x:Bind ViewModel.OpenRouterApiKey, Mode=TwoWay}" PasswordRevealMode="Peek" />
                        </settings:SettingsCard>
                    </settings:SettingsExpander.Items>
                </settings:SettingsExpander>

                <settings:SettingsExpander Header="Gemini" Description="OpenAI-compatible surface.">
                    <settings:SettingsExpander.Items>
                        <settings:SettingsCard Header="Endpoint">
                            <TextBox AutomationProperties.AutomationId="GeminiEndpointTextBox" MinWidth="320" Text="{x:Bind ViewModel.GeminiEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="API key" Description="Leave blank to use CALIPER_GEMINI_KEY.">
                            <PasswordBox AutomationProperties.AutomationId="GeminiApiKeyPasswordBox" MinWidth="220" Password="{x:Bind ViewModel.GeminiApiKey, Mode=TwoWay}" PasswordRevealMode="Peek" />
                        </settings:SettingsCard>
                    </settings:SettingsExpander.Items>
                </settings:SettingsExpander>

                <settings:SettingsExpander Header="OpenAI" Description="OpenAI Platform billing with an API key.">
                    <settings:SettingsExpander.Items>
                        <settings:SettingsCard Header="Endpoint">
                            <TextBox AutomationProperties.AutomationId="OpenAIEndpointTextBox" MinWidth="320" Text="{x:Bind ViewModel.OpenAIEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Organization" Description="Optional organization header.">
                            <TextBox AutomationProperties.AutomationId="OpenAIOrganizationTextBox" MinWidth="220" Text="{x:Bind ViewModel.OpenAIOrganization, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Project" Description="Optional project header.">
                            <TextBox AutomationProperties.AutomationId="OpenAIProjectTextBox" MinWidth="220" Text="{x:Bind ViewModel.OpenAIProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="API key" Description="Leave blank to use CALIPER_OPENAI_KEY.">
                            <PasswordBox AutomationProperties.AutomationId="OpenAIApiKeyPasswordBox" MinWidth="220" Password="{x:Bind ViewModel.OpenAIApiKey, Mode=TwoWay}" PasswordRevealMode="Peek" />
                        </settings:SettingsCard>
                    </settings:SettingsExpander.Items>
                </settings:SettingsExpander>

                <settings:SettingsExpander Header="OpenAI Codex" Description="Use your ChatGPT subscription through OAuth.">
                    <settings:SettingsExpander.Items>
                        <settings:SettingsCard Header="Account" Description="Caliper opens the OpenAI sign-in page in your browser.">
                            <StackPanel HorizontalAlignment="Right" Spacing="4">
                                <TextBlock HorizontalAlignment="Right" Text="{x:Bind ViewModel.OpenAICodexStatus, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.OpenAICodexAccount, Mode=OneWay}"
                                    Visibility="{x:Bind converters:XamlConverters.HasTextToVisibility(ViewModel.OpenAICodexAccount), Mode=OneWay}" />
                            </StackPanel>
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Authentication">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    AutomationProperties.AutomationId="SignInOpenAICodexButton"
                                    Command="{x:Bind ViewModel.SignInOpenAICodexCommand}"
                                    Content="Sign in"
                                    IsEnabled="{x:Bind converters:XamlConverters.InvertBool(ViewModel.IsBusy), Mode=OneWay}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsOpenAICodexSignedOut), Mode=OneWay}" />
                                <Button
                                    AutomationProperties.AutomationId="SignOutOpenAICodexButton"
                                    Command="{x:Bind ViewModel.SignOutOpenAICodexCommand}"
                                    Content="Sign out"
                                    IsEnabled="{x:Bind converters:XamlConverters.InvertBool(ViewModel.IsBusy), Mode=OneWay}"
                                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsOpenAICodexAuthenticated), Mode=OneWay}" />
                            </StackPanel>
                        </settings:SettingsCard>
                        <settings:SettingsCard Header="Endpoint" Description="Advanced: change only for a compatible Codex backend.">
                            <TextBox AutomationProperties.AutomationId="OpenAICodexEndpointTextBox" MinWidth="320" Text="{x:Bind ViewModel.OpenAICodexEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </settings:SettingsCard>
                    </settings:SettingsExpander.Items>
                </settings:SettingsExpander>
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasModels), Mode=OneWay}">
            <ListView
                AutomationProperties.AutomationId="ModelsList"
                ItemsSource="{x:Bind ViewModel.Models, Mode=OneWay}">
                <ListView.Header>
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Provider" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="Model" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="Capabilities" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="Default" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemContainerStyle>
                    <StaticResource ResourceKey="StretchListViewItemStyle" />
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModelItemViewModel">
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Provider}" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Id}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Capabilities}" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind DefaultText}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
