<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.ToolsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:vm="using:Caliper.App.ViewModels.Settings">

    <Grid Style="{StaticResource WidePageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Style="{StaticResource PageHeaderGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                <TextBlock Text="Tools" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.EnabledCountText, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                <Button AutomationProperties.AutomationId="DiscardToolsButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                <Button AutomationProperties.AutomationId="SaveToolsButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
            <InfoBar.ActionButton>
                <Button
                    AutomationProperties.AutomationId="ToolsRestartAppButton"
                    Click="RestartApp_Click"
                    Content="Restart Caliper"
                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
            </InfoBar.ActionButton>
        </InfoBar>
        <Grid Grid.Row="2" Padding="16,8" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Enabled" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock Grid.Column="1" Text="Tool" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock Grid.Column="2" Text="Description" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock Grid.Column="3" Text="Risk" Style="{StaticResource BodyStrongTextBlockStyle}" />
        </Grid>
        <Border Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}">
            <ListView
                AutomationProperties.AutomationId="ToolsList"
                ItemContainerStyle="{StaticResource StretchListViewItemStyle}"
                ItemsSource="{x:Bind ViewModel.Tools, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToolToggleViewModel">
                        <Grid Padding="16" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                AutomationProperties.AutomationId="{x:Bind Name}"
                                VerticalAlignment="Center"
                                IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Description}" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{x:Bind SideEffect}" Style="{StaticResource CaptionTextBlockStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
