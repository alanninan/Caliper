<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.McpServersSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels.Settings">

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource WidePageShellStyle}">
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="MCP servers" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="External tool servers connected to the runtime." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}">
                    <Button AutomationProperties.AutomationId="McpReconnectButton" Command="{x:Bind ViewModel.ReconnectCommand}" Content="Reconnect all" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                        <Button AutomationProperties.AutomationId="DiscardMcpButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                        <Button AutomationProperties.AutomationId="SaveMcpButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button
                        AutomationProperties.AutomationId="McpRestartAppButton"
                        Click="RestartApp_Click"
                        Content="Restart Caliper"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <Border MaxWidth="{StaticResource EmptyStateWidth}" Padding="28,24" HorizontalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Visibility="{x:Bind converters:XamlConverters.InvertBoolToVisibility(ViewModel.HasConfiguredServers), Mode=OneWay}">
                <StackPanel Spacing="16">
                    <TextBlock HorizontalAlignment="Center" Text="Add an MCP server" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Connect a local command or a web server to add external tools." TextAlignment="Center" TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                        <Button AutomationProperties.AutomationId="AddLocalMcpServerButton" Command="{x:Bind ViewModel.AddServerWithTransportCommand}" CommandParameter="stdio" Content="Local command" Style="{StaticResource AccentButtonStyle}" />
                        <Button AutomationProperties.AutomationId="AddWebMcpServerButton" Command="{x:Bind ViewModel.AddServerWithTransportCommand}" CommandParameter="http" Content="Web server" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="12" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasConfiguredServers), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <settings:SettingsCard Header="Configured" Description="{x:Bind ViewModel.ServerCountText, Mode=OneWay}" />
                <settings:SettingsCard Grid.Column="1" Header="Tools" Description="{x:Bind ViewModel.ToolCountText, Mode=OneWay}" />
                <settings:SettingsCard Grid.Column="2" Header="Status" Description="{x:Bind ViewModel.HealthText, Mode=OneWay}" />
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasConfiguredServers), Mode=OneWay}">
                <ListView AutomationProperties.AutomationId="McpServerStatusList" ItemsSource="{x:Bind ViewModel.McpServers, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:McpStatusViewModel">
                            <Grid Padding="16" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Detail}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{x:Bind State}" Style="{StaticResource CaptionTextBlockStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Grid x:Name="McpEditorGrid" ColumnSpacing="16" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasConfiguredServers), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="McpListColumn" Width="*" />
                    <ColumnDefinition x:Name="McpDetailColumn" Width="0" />
                </Grid.ColumnDefinitions>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="CompactMcp" />
                        <VisualState x:Name="WideMcp">
                            <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1008" /></VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="McpListColumn.Width" Value="320" />
                                <Setter Target="McpDetailColumn.Width" Value="*" />
                                <Setter Target="McpListPanel.Visibility" Value="Visible" />
                                <Setter Target="McpDetailPanel.Visibility" Value="Visible" />
                                <Setter Target="McpDetailPanel.(Grid.Column)" Value="1" />
                                <Setter Target="McpBackButton.Visibility" Value="Collapsed" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <StackPanel x:Name="McpListPanel" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button AutomationProperties.AutomationId="AddMcpServerButton" Command="{x:Bind ViewModel.AddServerCommand}" Content="Add" />
                        <Button AutomationProperties.AutomationId="RemoveMcpServerButton" Command="{x:Bind ViewModel.RemoveSelectedServerCommand}" Content="Remove" />
                    </StackPanel>
                    <ListView
                        AutomationProperties.AutomationId="McpServerEditList"
                        MaxHeight="360"
                        ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedServer, Mode=TwoWay}"
                        SelectionChanged="McpServerList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:McpServerSettingViewModel">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind Summary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                <Border x:Name="McpDetailPanel" Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}" Visibility="Collapsed">
                    <StackPanel Spacing="8">
                    <Button x:Name="McpBackButton" AutomationProperties.AutomationId="McpBackButton" Click="McpBack_Click" Content="Back" />
                    <ContentControl Content="{x:Bind ViewModel.SelectedServer, Mode=OneWay}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:McpServerSettingViewModel">
                                <StackPanel Spacing="8" MinWidth="280">
                                    <TextBox AutomationProperties.AutomationId="McpNameTextBox" Header="Name" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox AutomationProperties.AutomationId="McpTypePicker" Header="Transport" SelectedItem="{x:Bind Type, Mode=TwoWay}">
                                        <x:String>stdio</x:String>
                                        <x:String>http</x:String>
                                    </ComboBox>
                                    <TextBox AutomationProperties.AutomationId="McpUrlTextBox" Header="HTTP URL" Text="{x:Bind Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox AutomationProperties.AutomationId="McpCommandTextBox" Header="stdio command" Text="{x:Bind Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox AutomationProperties.AutomationId="McpArgsTextBox" AcceptsReturn="True" Header="Arguments" MaxHeight="100" Text="{x:Bind ArgsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                    <PasswordBox AutomationProperties.AutomationId="McpBearerTokenPasswordBox" Header="Bearer token" Password="{x:Bind BearerToken, Mode=TwoWay}" PasswordRevealMode="Peek" />
                                    <TextBox AutomationProperties.AutomationId="McpHeadersTextBox" AcceptsReturn="True" Header="Headers" MaxHeight="100" PlaceholderText="Header-Name=value" Text="{x:Bind HeadersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
