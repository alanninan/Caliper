<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource WidePageShellStyle}">
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="General" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Theme and workspace root." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                    <Button AutomationProperties.AutomationId="DiscardGeneralSettingsButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                    <Button AutomationProperties.AutomationId="SaveGeneralSettingsButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button
                        AutomationProperties.AutomationId="GeneralRestartAppButton"
                        Click="RestartApp_Click"
                        Content="Restart Caliper"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
                </InfoBar.ActionButton>
            </InfoBar>
            <settings:SettingsCard Header="Theme" Description="Applies immediately. High Contrast follows Windows automatically.">
                <ComboBox
                    x:Name="ThemePicker"
                    AutomationProperties.AutomationId="ThemePicker"
                    MinWidth="180"
                    ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                    SelectionChanged="ThemePicker_SelectionChanged" />
            </settings:SettingsCard>
            <settings:SettingsCard Header="Working root" Description="Folder the agent treats as the project root.">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox
                        AutomationProperties.AutomationId="SettingsWorkingRootTextBox"
                        MinWidth="320"
                        Text="{x:Bind ViewModel.WorkingRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button AutomationProperties.AutomationId="BrowseWorkingRootButton" Click="BrowseWorkingRoot_Click" Content="Browse" />
                </StackPanel>
            </settings:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
