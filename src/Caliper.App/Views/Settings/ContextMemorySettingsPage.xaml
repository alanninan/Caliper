<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.ContextMemorySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource WidePageShellStyle}">
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="Context &amp; memory" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Control long conversations and the facts Caliper can remember." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                    <Button AutomationProperties.AutomationId="DiscardContextMemoryButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                    <Button AutomationProperties.AutomationId="SaveContextMemoryButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button
                        AutomationProperties.AutomationId="ContextMemoryRestartAppButton"
                        Click="RestartApp_Click"
                        Content="Restart Caliper"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <settings:SettingsExpander Header="Manage long conversations" Description="Summarize older messages before the model runs out of room.">
                <ToggleSwitch AutomationProperties.AutomationId="AutoCompactSwitch" IsOn="{x:Bind ViewModel.AutoCompact, Mode=TwoWay}" />
                <settings:SettingsExpander.Items>
                    <settings:SettingsCard Header="Start summarizing at" Description="Percentage of the model's conversation capacity.">
                        <NumberBox AutomationProperties.AutomationId="CompactFractionNumberBox" Minimum="10" Maximum="99" SmallChange="5" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.CompactAtPercent, Mode=TwoWay}" />
                    </settings:SettingsCard>
                    <settings:SettingsCard Header="Keep recent turns" Description="For example, 4 keeps the last four user-and-assistant exchanges unchanged.">
                        <NumberBox AutomationProperties.AutomationId="KeepTurnsNumberBox" Minimum="1" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.KeepRecentTurns, Mode=TwoWay}" />
                    </settings:SettingsCard>
                    <settings:SettingsCard Header="Reserved output tokens" Visibility="Collapsed">
                        <NumberBox AutomationProperties.AutomationId="ReservedTokensNumberBox" Minimum="1" SmallChange="512" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.ReservedOutputTokens, Mode=TwoWay}" />
                    </settings:SettingsCard>
                </settings:SettingsExpander.Items>
            </settings:SettingsExpander>
            <Expander Header="Advanced">
                <settings:SettingsCard Header="Reserved output tokens" Description="Conversation capacity kept available for the model's reply.">
                    <NumberBox AutomationProperties.AutomationId="ReservedTokensAdvancedNumberBox" Minimum="1" SmallChange="512" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.ReservedOutputTokens, Mode=TwoWay}" />
                </settings:SettingsCard>
            </Expander>

            <settings:SettingsExpander Header="Memory" Description="Persistent memory locations and the project document name.">
                <ToggleSwitch AutomationProperties.AutomationId="MemoryEnabledSwitch" IsOn="{x:Bind ViewModel.MemoryEnabled, Mode=TwoWay}" />
                <settings:SettingsExpander.Items>
                    <settings:SettingsCard Header="Global memory directory">
                        <TextBox AutomationProperties.AutomationId="MemoryGlobalDirTextBox" MinWidth="280" Text="{x:Bind ViewModel.MemoryGlobalDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </settings:SettingsCard>
                    <settings:SettingsCard Header="Project memory file">
                        <TextBox AutomationProperties.AutomationId="MemoryProjectFileTextBox" MinWidth="220" Text="{x:Bind ViewModel.MemoryProjectFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </settings:SettingsCard>
                </settings:SettingsExpander.Items>
            </settings:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</Page>
