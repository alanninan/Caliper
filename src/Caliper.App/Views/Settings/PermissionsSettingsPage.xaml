<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.PermissionsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls">

    <Page.Resources>
        <DataTemplate x:Key="AllowlistRowTemplate" x:DataType="x:String">
            <Grid Padding="8,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind}" TextWrapping="Wrap" FontFamily="{StaticResource CodeFontFamily}" />
                <Button Grid.Column="1" AutomationProperties.Name="Remove allowed command" Click="RemoveAllowlistEntry_Click" Tag="{x:Bind}" Content="Remove" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="DenylistRowTemplate" x:DataType="x:String">
            <Grid Padding="8,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind}" TextWrapping="Wrap" FontFamily="{StaticResource CodeFontFamily}" />
                <Button Grid.Column="1" AutomationProperties.Name="Remove blocked command" Click="RemoveDenylistEntry_Click" Tag="{x:Bind}" Content="Remove" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FileRootRowTemplate" x:DataType="x:String">
            <Grid Padding="8,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind}" TextWrapping="Wrap" FontFamily="{StaticResource CodeFontFamily}" />
                <Button Grid.Column="1" AutomationProperties.Name="Remove approved path" Click="RemoveFileRootEntry_Click" Tag="{x:Bind}" Content="Remove" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource WidePageShellStyle}">
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="Permissions" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="How side-effecting tools are handled during runs." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                    <Button AutomationProperties.AutomationId="DiscardPermissionsButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                    <Button AutomationProperties.AutomationId="SavePermissionsButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button
                        AutomationProperties.AutomationId="PermissionsRestartAppButton"
                        Click="RestartApp_Click"
                        Content="Restart Caliper"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <StackPanel Spacing="8">
                <TextBlock Text="Choose what Caliper may do" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButton x:Name="PermissionAskChoice" AutomationProperties.AutomationId="PermissionAskChoice" Content="Ask before actions" Tag="AskAlways" Checked="PermissionChoice_Checked" />
                <TextBlock Margin="32,0,0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Caliper asks before any action that can change files, run commands, or affect external systems." TextWrapping="Wrap" />
                <RadioButton x:Name="PermissionAutoChoice" AutomationProperties.AutomationId="PermissionAutoChoice" Content="Allow safe and approved actions" Tag="Auto" Checked="PermissionChoice_Checked" />
                <TextBlock Margin="32,0,0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Read-only work and actions matching your approved rules can continue without interruption." TextWrapping="Wrap" />
                <RadioButton x:Name="PermissionPlanChoice" AutomationProperties.AutomationId="PermissionPlanChoice" Content="Planning only" Tag="Plan" Checked="PermissionChoice_Checked" />
                <TextBlock Margin="32,0,0,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Caliper can inspect and propose work, but cannot make changes." TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch AutomationProperties.AutomationId="RememberApprovalsSwitch" Header="Remember 'Allow for session' approvals" IsOn="{x:Bind ViewModel.RememberApprovals, Mode=TwoWay}" />

            <Expander Header="Advanced rules" HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock Text="Shell auto-allowlist" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Command prefixes allowed automatically in Auto mode." Style="{StaticResource CaptionTextBlockStyle}" />
                <!-- D5: no SelectedItem binding is used here — each row removes itself via its
                     own "Remove" button (Tag-carried value), so a ListView's selection/scrolling
                     machinery isn't needed. Converted to a non-scrolling ItemsControl; the short
                     allowlist now flows into the page's own ScrollViewer instead of scrolling
                     in its own MaxHeight box. -->
                <ItemsControl AutomationProperties.AutomationId="ShellAllowlistList" ItemsSource="{x:Bind ViewModel.ShellAutoAllowlist, Mode=OneWay}" ItemTemplate="{StaticResource AllowlistRowTemplate}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewAllowlistEntry" AutomationProperties.AutomationId="NewAllowlistEntryTextBox" PlaceholderText="git status" />
                    <Button Grid.Column="1" Click="AddAllowlistEntry_Click" Content="Add" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Shell denylist" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Command fragments that always require approval, in every mode." Style="{StaticResource CaptionTextBlockStyle}" />
                <!-- D5: same reasoning as ShellAllowlistList above — per-row Remove buttons, no
                     ListView selection needed. -->
                <ItemsControl AutomationProperties.AutomationId="ShellDenylistList" ItemsSource="{x:Bind ViewModel.ShellDenylist, Mode=OneWay}" ItemTemplate="{StaticResource DenylistRowTemplate}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewDenylistEntry" AutomationProperties.AutomationId="NewDenylistEntryTextBox" PlaceholderText="rm -rf" />
                    <Button Grid.Column="1" Click="AddDenylistEntry_Click" Content="Add" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Auto-allow file roots" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Paths outside the working root that file tools may access without a prompt." Style="{StaticResource CaptionTextBlockStyle}" />
                <!-- D5: same reasoning as ShellAllowlistList above — per-row Remove buttons, no
                     ListView selection needed. -->
                <ItemsControl AutomationProperties.AutomationId="FileRootsList" ItemsSource="{x:Bind ViewModel.AutoAllowFileRoots, Mode=OneWay}" ItemTemplate="{StaticResource FileRootRowTemplate}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewFileRootEntry" AutomationProperties.AutomationId="NewFileRootEntryTextBox" PlaceholderText="C:\shared" />
                    <Button Grid.Column="1" Click="AddFileRootEntry_Click" Content="Add" />
                </Grid>
            </StackPanel>
            </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
