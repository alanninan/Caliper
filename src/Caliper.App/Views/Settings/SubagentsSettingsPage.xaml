<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Caliper.App.Views.Settings.SubagentsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caliper.App.Controls"
    xmlns:settings="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Caliper.App.ViewModels.Settings">

    <Page.Resources>
        <DataTemplate x:Key="ProfileRowTemplate" x:DataType="vm:SubagentProfileItemViewModel">
            <StackPanel Spacing="2">
                <TextBlock Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind SummaryCaption, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ProfileDetailTemplate" x:DataType="vm:SubagentProfileItemViewModel">
            <StackPanel Spacing="12">
                <TextBox AutomationProperties.AutomationId="ProfileNameTextBox" Header="Profile name" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Spacing="8">
                    <TextBox
                        AutomationProperties.AutomationId="ProfileToolSearchBox"
                        Header="Tools this profile can use"
                        PlaceholderText="Search tools"
                        Text="{x:Bind ToolSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ItemsControl ItemsSource="{x:Bind FilteredToolChoices, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SubagentToolChoiceViewModel">
                                <CheckBox Content="{x:Bind Name, Mode=OneTime}" IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <NumberBox AutomationProperties.AutomationId="ProfileMaxStepsNumberBox" Header="Max steps" Minimum="1" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind MaxSteps, Mode=TwoWay}" />
                <StackPanel Spacing="4">
                    <ComboBox AutomationProperties.AutomationId="ProfileModePicker" Header="Mode" MinWidth="200" SelectedItem="{x:Bind ModeText, Mode=TwoWay}">
                        <x:String>Inherit parent</x:String>
                        <x:String>Ask before actions</x:String>
                        <x:String>Allow safe and approved actions</x:String>
                        <x:String>Planning only</x:String>
                    </ComboBox>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="A profile can only be as permissive as its parent run. Inherit parent uses the parent's choice."
                        TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ValidationMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(HasValidationMessage), Mode=OneWay}" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer Style="{StaticResource PageScrollViewerStyle}">
        <StackPanel Style="{StaticResource WidePageShellStyle}">
            <Grid Style="{StaticResource PageHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Style="{StaticResource PageHeaderTextStyle}">
                    <TextBlock Text="Subagents" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Choose which tools delegated tasks can use and how carefully they may act." TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsStyle}">
                    <Button AutomationProperties.AutomationId="AddSubagentProfileButton" Command="{x:Bind ViewModel.AddProfileCommand}" Content="Add" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.IsDirty), Mode=OneWay}">
                        <Button AutomationProperties.AutomationId="DiscardSubagentsButton" Command="{x:Bind ViewModel.DiscardCommand}" Content="Discard" />
                        <Button AutomationProperties.AutomationId="SaveSubagentsButton" Command="{x:Bind ViewModel.SaveCommand}" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind converters:XamlConverters.HasText(ViewModel.StatusMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="{x:Bind converters:XamlConverters.StatusSeverity(ViewModel.StatusIsError), Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button
                        AutomationProperties.AutomationId="SubagentsRestartAppButton"
                        Click="RestartApp_Click"
                        Content="Restart Caliper"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.RestartRequired), Mode=OneWay}" />
                </InfoBar.ActionButton>
            </InfoBar>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <NumberBox AutomationProperties.AutomationId="MaxDepthNumberBox" Header="Max depth" Minimum="1" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.MaxDepth, Mode=TwoWay}" />
                    <NumberBox Grid.Column="1" AutomationProperties.AutomationId="MaxChildrenPerRunNumberBox" Header="Max children per run" Minimum="1" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.MaxChildrenPerRun, Mode=TwoWay}" />
                    <NumberBox Grid.Column="2" AutomationProperties.AutomationId="SubagentTimeoutNumberBox" Header="Timeout (seconds)" Minimum="1" SmallChange="30" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.TimeoutSeconds, Mode=TwoWay}" />
                    <ComboBox
                        Grid.Column="3"
                        AutomationProperties.AutomationId="DefaultProfilePicker"
                        Header="Default profile"
                        AutomationProperties.HelpText="Used when a delegated task does not request a named profile."
                        ItemsSource="{x:Bind ViewModel.ProfileNameOptions, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.DefaultProfile, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border
                MaxWidth="480"
                Padding="28,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource OverlayCornerRadius}"
                Visibility="{x:Bind converters:XamlConverters.InvertBoolToVisibility(ViewModel.HasProfiles), Mode=OneWay}">
                <StackPanel Spacing="16">
                    <FontIcon HorizontalAlignment="Center" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE716;" />
                    <TextBlock HorizontalAlignment="Center" Text="No profiles" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Add a profile to give the task tool a named, restricted set of tools a subagent may use."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Center"
                        AutomationProperties.AutomationId="EmptyStateAddProfileButton"
                        Command="{x:Bind ViewModel.AddProfileCommand}"
                        Content="Add profile"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <Grid x:Name="SubagentEditorGrid" ColumnSpacing="16" Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasProfiles), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SubagentListColumn" Width="*" />
                    <ColumnDefinition x:Name="SubagentDetailColumn" Width="0" />
                </Grid.ColumnDefinitions>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="CompactSubagents" />
                        <VisualState x:Name="WideSubagents">
                            <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="1008" /></VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SubagentListColumn.Width" Value="320" />
                                <Setter Target="SubagentDetailColumn.Width" Value="*" />
                                <Setter Target="SubagentListPanel.Visibility" Value="Visible" />
                                <Setter Target="SubagentDetailPanel.Visibility" Value="Visible" />
                                <Setter Target="SubagentDetailPanel.(Grid.Column)" Value="1" />
                                <Setter Target="SubagentBackButton.Visibility" Value="Collapsed" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <StackPanel x:Name="SubagentListPanel" Spacing="8">
                    <Button
                        AutomationProperties.AutomationId="RemoveSubagentProfileButton"
                        HorizontalAlignment="Right"
                        Click="RemoveSelectedProfile_Click"
                        Content="Remove"
                        IsEnabled="{x:Bind ViewModel.CanRemoveSelected, Mode=OneWay}" />
                    <TextBlock
                        AutomationProperties.AutomationId="RemoveBlockedReasonText"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.RemoveBlockedReason, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind converters:XamlConverters.BoolToVisibility(ViewModel.HasRemoveBlockedReason), Mode=OneWay}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource OverlayCornerRadius}">
                        <ListView
                            AutomationProperties.AutomationId="SubagentProfileList"
                            ItemTemplate="{StaticResource ProfileRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                            MaxHeight="480"
                            SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                            SelectionChanged="SubagentProfileList_SelectionChanged"
                            SelectionMode="Single" />
                    </Border>
                </StackPanel>
                <Border
                    x:Name="SubagentDetailPanel"
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                    <Button x:Name="SubagentBackButton" AutomationProperties.AutomationId="SubagentBackButton" Click="SubagentBack_Click" Content="Back" />
                    <ContentControl
                        HorizontalContentAlignment="Stretch"
                        Content="{x:Bind ViewModel.SelectedProfile, Mode=OneWay}"
                        ContentTemplate="{StaticResource ProfileDetailTemplate}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
