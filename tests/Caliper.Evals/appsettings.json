{
  "Caliper": {
    "Provider": "OpenRouter",
    "Model": "openrouter/model-slug",
    "MaxSteps": 8,
    "DuplicateCallLimit": 2,
    "ToolTimeoutSeconds": 30,
    "ToolMaxRetries": 2,
    "ToolOutputMaxChars": 8000,
    "Temperature": 0.0,
    "Seed": 42,
    "Reasoning": { "Effort": "medium", "Exclude": false },
    "TurnStrategy": "Auto",
    "EnabledTools": [ "search", "fetch_url", "read_file", "list_dir", "glob", "grep", "write_file", "edit_file", "bash", "powershell", "memory", "load_skill" ],
    "WorkingRoot": ".",
    "SkillsDirectory": "./skills",
    "SkillSelector": "None",
    "MaxSurfacedSkills": 12,
    "Context": {
      "AutoCompact": true,
      "CompactAtFraction": 0.8,
      "KeepRecentTurns": 8,
      "ReservedOutputTokens": 1024
    },
    "Memory": {
      "Enabled": false,
      "GlobalDir": "~/.caliper/memory",
      "ProjectFile": "CALIPER.md"
    }
  },
  "Providers": {
    "OpenRouter": {
      "Endpoint": "https://openrouter.ai/api/v1",
      "AppTitle": "Caliper Evals"
    }
  },
  "Permissions": {
    "Mode": "AskAlways",
    "RememberApprovals": false,
    "ShellAutoAllowlist": [ "git status", "git diff --", "dotnet build", "dotnet test" ],
    "ShellDenylist": [ "rm -rf", "sudo ", "mkfs", "dd ", ":(){", "curl", "wget", "Remove-Item -Recurse", "Format-Volume", "reg delete" ],
    "AutoAllowFileRoots": []
  },
  "Mcp": {
    "Servers": {}
  },
  "Search": {
    "Backend": "Stub",
    "SearchDepth": "basic",
    "MaxResults": 5,
    "Topic": "general"
  },
  "Persistence": {
    "SqlitePath": "./caliper.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  }
}
